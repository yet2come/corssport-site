{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "crossport.site"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.crossport.site"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.crossport.cc"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "xmo.jp"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.xmo.jp"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "cpx.xmo.jp"
        }
      ],
      "destination": "https://crossport.cc/:path",
      "permanent": true
    },
    {
      "source": "/events.html",
      "destination": "/events/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin{,-manual}.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
